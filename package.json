{
  "devDependencies": {
    "markdownlint-cli2": "0.23.1",
    "prettier": "3.9.5"
  },
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "name": "tessera-tooling",
  "private": true,
  "scripts": {
    "check:markup": "prettier --check . && markdownlint-cli2 \"**/*.md\" \"!**/*.docc/**/*.md\" \"!**/.build/**/*.md\" \"!Packages/**/*.md\" \"!node_modules/**/*.md\"",
    "format:markup": "prettier --write ."
  }
}
