# Tessera Windows (Frost) machine-local config — TEMPLATE.
#
# Copy this to a gitignored .windows-frost.env at the repo root (or point TESSERA_FROST_ENV
# at another path). scripts/windows-frost-env.sh sources it automatically, so the
# `just windows-frost ...` recipes run without env prefixes:
#
#   cp scripts/config/frost/windows-frost.env.example .windows-frost.env
#
# The ${VAR:-…} idiom means an explicit `env VAR=… just …` still overrides any line here.

# Frost checkout, if it is not at the default ~/Developer/frost.
export TESSERA_FROST_ROOT="${TESSERA_FROST_ROOT:-$HOME/Developer/frost}"

# Locally downloaded ISOs (see docs/WindowsFrostVM.md section 3). Use your real filenames.
export TESSERA_FROST_WINDOWS_ISO="${TESSERA_FROST_WINDOWS_ISO:-$HOME/Downloads/Win11_ARM64.iso}"
export TESSERA_FROST_VIRTIO_ISO="${TESSERA_FROST_VIRTIO_ISO:-$HOME/Downloads/virtio-win.iso}"

# Optional override. The golden disks otherwise default to
# ${XDG_STATE_HOME:-~/.local/state}/tessera/windows-frost — outside the repo, so
# `just core clean` cannot wipe them and every worktree shares one build.
# export TESSERA_FROST_WORK="${TESSERA_FROST_WORK:-$HOME/.local/state/tessera/windows-frost}"
