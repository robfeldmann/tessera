# macOS
.DS_Store

# Obsidian vault config (design/ is openable as a vault)
design/.obsidian/

# Homebrew Bundle lockfile
Brewfile.lock.json

# libghostty-vt headers materialized by scripts/build-libghostty-vt.{sh,ps1}
Sources/CGhosttyVT/include/ghostty/

# pre-commit
.pre-commit/

# pi local settings
.pi/settings.json

# Frost Windows VM machine-local config
.windows-frost.env

# Python
__pycache__/
*.py[cod]

# SwiftLint cache
.swiftlint.yml.cache

# swift-format cache
.swift-format-cache/

# Swift Package Manager
.build/
.swiftpm/*
!.swiftpm/xcode/
!.swiftpm/xcode/xcshareddata/
!.swiftpm/xcode/xcshareddata/xcschemes/
!.swiftpm/xcode/xcshareddata/xcschemes/*.xcscheme
!.swiftpm/xcode/xcshareddata/xctestplans/
!.swiftpm/xcode/xcshareddata/xctestplans/*.xctestplan
!Examples/.swiftpm/
!Examples/.swiftpm/xcode/
!Examples/.swiftpm/xcode/xcshareddata/
!Examples/.swiftpm/xcode/xcshareddata/xcschemes/
!Examples/.swiftpm/xcode/xcshareddata/xcschemes/*.xcscheme
Packages/
*.xcodeproj/
*.xcworkspace/
!Tessera.xcworkspace/
!Tessera.xcworkspace/contents.xcworkspacedata

# Xcode
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.moved-aside
profile
